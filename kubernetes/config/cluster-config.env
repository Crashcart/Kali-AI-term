# Kubernetes Cluster Configuration
# Generated: 2026-04-13
# This file stores your cluster configuration
# Edit this file to customize your setup

################################################################################
# CLUSTER INFORMATION
################################################################################

CLUSTER_NAME="multi-node-cluster"
K8S_TYPE="k3s"              # k3s (lightweight) or kubeadm (standard)
CNI_PLUGIN="flannel"        # flannel or calico
KUBE_VERSION="latest"       # Kubernetes version

################################################################################
# CONTROL PLANE CONFIGURATION
################################################################################

# IP address of your control plane / master node
CONTROL_PLANE_IP=""         # Example: 192.168.1.10

# If using kubeadm, token for joining workers (auto-generated, do not edit)
KUBEADM_TOKEN=""
KUBEADM_CERT_HASH=""

################################################################################
# NETWORKING CONFIGURATION
################################################################################

# Pod network CIDR - addresses for pods across the cluster
POD_SUBNET="10.244.0.0/16"

# Service network CIDR - addresses for Kubernetes services
SERVICE_SUBNET="10.96.0.0/12"

# Internal DNS domain
DNS_DOMAIN="cluster.local"

################################################################################
# ZEROTIER CONFIGURATION (Virtual Network)
################################################################################

# Your ZeroTier One network ID (if applicable)
ZEROTIER_NETWORK_ID=""      # Example: 12ac4a63c9a4520f

# Control plane node's ZeroTier address
ZEROTIER_MEMBER_ID=""       # Example: 462d8eabc4

# ZeroTier IP address of control plane (used for node joining)
ZEROTIER_CONTROL_PLANE_IP=""  # Example: 172.26.0.1

################################################################################
# NODE CAPACITY PLANNING
################################################################################

# Expected number of Linux worker nodes
EXPECTED_LINUX_NODES=3

# Expected number of Windows worker nodes
EXPECTED_WINDOWS_NODES=2

################################################################################
# DOCKER CONFIGURATION
################################################################################

# Docker registry URL (leave empty for Docker Hub)
DOCKER_REGISTRY=""

# Allow insecure registry connections (not recommended for production)
INSECURE_REGISTRY=false

# Docker daemon log level (debug, info, warn, error)
DOCKER_LOG_LEVEL="info"

# Docker storage driver (overlay2 recommended for Linux)
DOCKER_STORAGE_DRIVER="overlay2"

################################################################################
# MONITORING & HEALTH CHECK CONFIGURATION
################################################################################

# Health check interval in seconds
HEALTH_CHECK_INTERVAL=30

# Number of failed checks before marking node as unhealthy
HEALTH_CHECK_FAILURE_THRESHOLD=3

# Automatically cordon failed nodes (true/false)
AUTO_CORDON_FAILED_NODES=true

# Send alerts on node failures (not implemented yet)
ENABLE_ALERTS=false
ALERT_EMAIL=""

################################################################################
# LOGGING CONFIGURATION
################################################################################

# Log directory
LOG_DIR="./logs"

# Retain logs for N days
LOG_RETENTION_DAYS=30

# Log level (debug, info, warn, error)
LOG_LEVEL="info"

################################################################################
# ADVANCED CONFIGURATION
################################################################################

# Enable IPv6 (if your network supports it)
ENABLE_IPV6=false

# Network policy enforcement
ENABLE_NETWORK_POLICIES=true

# Pod security policy
ENABLE_POD_SECURITY=true

# Node drain timeout (seconds)
NODE_DRAIN_TIMEOUT=300

# Pod eviction timeout (seconds)
POD_EVICTION_TIMEOUT=300
