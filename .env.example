# Kali Hacker Bot Configuration Template

# ============================================
# Application Settings
# ============================================

# Node.js environment (production or development)
NODE_ENV=production

# Express server port (internal, maps to APP_PORT externally)
PORT=3000

# External port mapping (docker-compose PORT:INTERNAL_PORT)
APP_PORT=31337

# Bind address (0.0.0.0 for all interfaces, localhost for local only)
BIND_HOST=0.0.0.0

# ============================================
# Ollama Configuration (External Service)
# ============================================

# IMPORTANT: Ollama is NOT bundled with Kali bot. Install separately from:
# https://github.com/Crashcart/Ollama-intelgpu

# Ollama API endpoint - point to external Ollama instance
# For Ollama on host machine (Docker Desktop): http://host.docker.internal:11434
# For Ollama on Linux host: http://localhost:11434 (or actual host IP)
# For remote Ollama instance: http://<IP>:11434
OLLAMA_URL=http://host.docker.internal:11434

# Default LLM model to use (must be already pulled in external Ollama)
# Recommended: smollm2:135m, phi3:mini, gemma3:4b, qwen2.5:3b
DEFAULT_OLLAMA_MODEL=smollm2:135m

# ============================================
# Docker & Container Settings
# ============================================

# Kali Linux container name (must match docker-compose.yml)
KALI_CONTAINER=kali-ai-term-kali

# ============================================
# Security
# ============================================

# Admin password for web UI authentication
# Generate: node -e "console.log(require('crypto').randomBytes(8).toString('hex'))"
ADMIN_PASSWORD=kalibot

# Session authentication secret (must be unique)
# Generate: node -e "console.log(require('crypto').randomUUID())"
AUTH_SECRET=changeme-generate-random-uuid

# ============================================
# Logging
# ============================================

# Log level: debug, info (default), warn, error
# debug   - Very verbose output for troubleshooting
# info    - Standard logging (recommended)
# warn    - Warnings and errors only
# error   - Errors only
LOG_LEVEL=info

# ============================================
# Database
# ============================================

# Database file location (relative to app root)
DB_PATH=./data/kali.db

# ============================================
# Optional Settings
# ============================================

# Installation diagnostic file (auto-generated)
# DIAGNOSTIC_FILE=./install.diagnostic

# Custom data directory for persistence
# DATA_DIR=./data
