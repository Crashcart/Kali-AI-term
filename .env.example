# Kali Hacker Bot Configuration Template
# Copy this to .env and customize for your environment

# ============================================
# Application Settings
# ============================================

# Node.js environment (production or development)
NODE_ENV=production

# Express server port
PORT=3000

# Bind address (0.0.0.0 for all interfaces, localhost for local only)
BIND_HOST=0.0.0.0

# ============================================
# Ollama Configuration
# ============================================

# Ollama API endpoint (running in Docker container)
# Use http://ollama:11434 when running via docker-compose
# Use http://host.docker.internal:11434 for Docker Desktop on macOS
# Use http://192.168.1.100:11434 for remote Ollama instance
OLLAMA_URL=http://ollama:11434

# Default Ollama model to use for chat completions
# Recommended for low-end systems: smollm2:135m (91 MB, ultra-light, 512 MB VRAM)
# For balanced performance: llama3.2:1b (770 MB, 2-3 GB VRAM)
# For high-end systems: llama3.2:3b or mistral (4+ GB VRAM)
DEFAULT_OLLAMA_MODEL=smollm2:135m

# Ollama model temperature (0.0-1.0, higher = more creative/random)
OLLAMA_TEMPERATURE=0.7

# Ollama model top_p sampling (0.0-1.0, nucleus sampling parameter)
OLLAMA_TOP_P=0.9

# ============================================
# Docker & Container Settings
# ============================================

# Kali Linux container name (must match docker-compose.yml)
KALI_CONTAINER=kali-ai-term-kali

# ============================================
# Security
# ============================================

# Admin password for web UI authentication
# Generate secure password: node -e "console.log(require('crypto').randomBytes(8).toString('hex'))"
ADMIN_PASSWORD=kalibot

# Session authentication secret (must be unique)
# Generate: node -e "console.log(require('crypto').randomUUID())"
AUTH_SECRET=your-random-uuid-here-replace-this

# ============================================
# Logging
# ============================================

# Log level: debug, info (default), warn, error
# debug   - Very verbose output for troubleshooting
# info    - Standard logging (recommended)
# warn    - Warnings and errors only
# error   - Errors only
LOG_LEVEL=info

# ============================================
# Database
# ============================================

# Database file location (relative to app root)
DB_PATH=./data/kali.db

# ============================================
# Optional Settings
# ============================================

# Installation diagnostic file (auto-generated)
# DIAGNOSTIC_FILE=./install.diagnostic

# Custom data directory for persistence
# DATA_DIR=./data
